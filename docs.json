            "href": "/quickstart"
          }
        }
      },
      {
        "language": "vi",
        "groups": [
          {
            "group": "Bắt đầu",
            "pages": [
              "vi/index",
              "vi/quickstart",
              "vi/getting-started/shared-configuration"
            ]
          },
          {
            "group": "Hướng dẫn CLI",
            "pages": [
              "vi/cli-tools/claude-code",
              "vi/cli-tools/codex-cli",
              "vi/cli-tools/opencode",
              "vi/cli-tools/cursor",
              "vi/cli-tools/cline-continue-roo",
              "vi/cli-tools/mitm-tools"
            ]
          },
          {
            "group": "Tham khảo",
            "pages": [
              "vi/reference/model-paths",
              "vi/reference/troubleshooting",
              "vi/reference/notice"
            ]
          }
        ],
        "navbar": {
          "links": [
            {
              "label": "GitHub",
              "href": "https://github.com/png261/mintlify-docs"
            }
          ],
          "primary": {
            "type": "button",
