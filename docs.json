{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "appleai.codes Docs",
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Docs",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "getting-started/shared-configuration"
            ]
          },
          {
            "group": "CLI setup guides",
            "pages": [
              "cli-tools/claude-code",
              "cli-tools/codex-cli",
              "cli-tools/opencode",
              "cli-tools/cursor",
              "cli-tools/cline-continue-roo",
              "cli-tools/mitm-tools"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "reference/model-paths",
              "reference/troubleshooting",
              "reference/notice"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Quickstart",
          "href": "/quickstart",
          "icon": "rocket"
        },
        {
          "anchor": "Notice",
          "href": "/reference/notice",
          "icon": "triangle-exclamation"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/png261/mintlify-docs"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Quickstart",
      "href": "/quickstart"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/png261/mintlify-docs"
    }
  }
}
